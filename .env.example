# --- Supabase ---
# プロジェクトの Settings > API から取得
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 管理系処理用。絶対にフロント(ブラウザ)へ出さない。NEXT_PUBLIC_ を付けない。
SUPABASE_SERVICE_ROLE_KEY=

# --- 管理画面 ---
# /admin のログインパスワード（初期版の簡易認証）
ADMIN_PASSWORD=

# --- keep-alive ---
# /api/health を保護する任意のトークン。外部監視サービスからのpingに
#   ?token=... を付けて叩く。空ならトークンなしでも応答する。
HEALTH_TOKEN=
